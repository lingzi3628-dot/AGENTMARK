{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bun run vercel-build",
  "installCommand": "bun install --frozen-lockfile",
  "git": {
    "deploymentEnabled": true
  },
  "functions": {
    "src/app/api/webhooks/*/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/agents/[id]/run/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/triggers/*/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/email/poll/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/voice/*/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/scheduler/tick", "schedule": "* * * * *" },
    { "path": "/api/email/poll", "schedule": "*/5 * * * *" }
  ]
}
