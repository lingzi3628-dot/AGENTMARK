// AGENTMARK — AI Agent Studio schema (V2 — adds teams, versions, scheduling, marketplace, cost tracking, RAG)
//
// Database provider is auto-detected from the DATABASE_URL:
//   - If DATABASE_URL starts with "postgresql://" or "postgres://" → uses Postgres (Vercel/Neon/Supabase)
//   - Otherwise → uses SQLite (local dev, Railway persistent volume)
//
// No manual schema edits needed when switching environments.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  firebaseUid     String   @unique
  email           String   @unique
  name            String   @default("")
  photoURL        String   @default("")
  plan            String   @default("free") // free | pro | team
  // BYOK: built-in provider keys (encrypted at rest via src/lib/crypto.ts)
  glmApiKey       String   @default("")
  openaiApiKey    String   @default("")
  anthropicApiKey String   @default("")
  // Supabase connection for heavy projects
  supabaseUrl     String   @default("")
  supabaseAnonKey String   @default("")
  supabaseServiceKey String @default("")
  // limits — FREE plan = 2 agents max
  dailyTokenLimit Int      @default(100000)
  maxAgents       Int      @default(2)
  // token accounting (reset daily)
  tokensUsedToday Int      @default(0)
  tokenResetDate  String   @default("") // YYYY-MM-DD
  // spend tracking (USD cents — avoids float precision issues)
  spendUsedTodayCents Int  @default(0)
  spendResetDate  String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  agents          Agent[]
  runs            RunHistory[]
  usageRecords    UsageRecord[]
  customApis      CustomApi[]
  conversations   CustomerConversation[]
  // Stripe billing (optional — empty on free tier)
  stripeCustomerId   String   @default("")
  stripeSubscriptionId String @default("")
  stripePriceId      String   @default("")
  // Team memberships
  teamMemberships TeamMember[]
  // Teams owned by this user (opposite of Team.owner)
  ownedTeams      Team[]
  // Public API keys (for programmatic access via REST API)
  apiKeys         ApiKey[]
  // Agent versions authored by this user (opposite of AgentVersion.createdBy)
  authoredVersions AgentVersion[]
  // Audit log entries authored by this user
  auditLogs       AuditLog[]
}

model Agent {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  icon        String   @default("sparkles")
  category    String   @default("custom")
  nodes       String   @default("[]")
  edges       String   @default("[]")
  pinned      Boolean  @default(false)
  // Latest published version number (auto-incremented on save)
  currentVersion Int   @default(1)
  // Marketplace: if publishedId is set, this agent is a fork of a marketplace template
  publishedTemplateId String @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  runs        RunHistory[]
  knowledge   KnowledgeItem[]
  published   PublishedAgent?
  integrations Integration[]
  versions    AgentVersion[]
  schedules   Schedule[]
  webhookTriggers WebhookTrigger[]
  // Cost tracking
  costRecords CostRecord[]
  // RAG: documents embedded for retrieval
  documents   Document[]
}

// Agent version history — every save snapshots the graph
model AgentVersion {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  version     Int
  nodes       String   @default("[]")
  edges       String   @default("[]")
  name        String   @default("")
  description String   @default("")
  // Branch support: a version can be on a branch (e.g. "main", "experiment-1")
  branch      String   @default("main")
  // Optional commit message
  message     String   @default("")
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@unique([agentId, version, branch])
  @@index([agentId, branch])
}

model RunHistory {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  input     String   @default("")
  output    String   @default("")
  status    String   @default("completed")
  tokens    Int      @default(0)
  duration  Int      @default(0)
  // Cost in USD cents (matches spendUsedTodayCents on User)
  costCents Int      @default(0)
  // Source: manual (Run button), schedule, webhook, api, integration
  source    String   @default("manual")
  createdAt DateTime @default(now())
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // YYYY-MM-DD
  tokens    Int      @default(0)
  runs      Int      @default(0)
  costCents Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

// Per-agent cost rollup (refreshed on each run)
model CostRecord {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId      String?
  // Day bucket (YYYY-MM-DD) for daily charts
  date        String
  tokens      Int      @default(0)
  runs        Int      @default(0)
  costCents   Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([agentId, date])
  @@index([agentId, date])
}

model KnowledgeItem {
  id        String   @id @default(cuid())
  agentId   String?
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title     String
  content   String   @default("")
  type      String   @default("text")
  source    String   @default("")
  createdAt DateTime @default(now())
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  icon        String   @default("sparkles")
  category    String   @default("productivity")
  tags        String   @default("")
  nodes       String   @default("[]")
  edges       String   @default("[]")
  featured    Boolean  @default(false)
  installs    Int      @default(0)
  createdAt   DateTime @default(now())
}

// Marketplace: user-published templates (separate from built-in Template table)
model TemplateShare {
  id          String   @id @default(cuid())
  // Slug for the marketplace URL e.g. /marketplace/email-triage-pro
  slug        String   @unique
  name        String
  description String   @default("")
  icon        String   @default("sparkles")
  category    String   @default("custom")
  tags        String   @default("")
  nodes       String   @default("[]")
  edges       String   @default("[]")
  // Author info
  authorId    String?
  authorName  String   @default("")
  authorAvatar String  @default("")
  // Stats
  installs    Int      @default(0)
  rating      Float    @default(0)
  ratingCount Int      @default(0)
  // Pricing: 0 = free, >0 = price in cents (marketplace takes 20%)
  priceCents  Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PublishedAgent {
  id        String   @id @default(cuid())
  agentId   String   @unique
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  slug      String   @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Integration {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  platform  String
  config    String   @default("{}")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  MessageLog[]
}

model MessageLog {
  id            String   @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  direction     String   // incoming | outgoing
  platform      String   // telegram | whatsapp | slack | email | voice | ...
  senderName    String   @default("")
  senderId      String   @default("")
  content       String   @default("")
  status        String   @default("delivered") // delivered | failed | pending
  tokens        Int      @default(0)
  costCents     Int      @default(0)
  durationMs    Int      @default(0)
  createdAt DateTime @default(now())
}

// User-supplied API keys for ANY provider (GLM, OpenAI, Anthropic, Mistral, Cohere, Together, Groq, custom OpenAI-compatible, etc.)
model CustomApi {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String
  provider    String
  baseUrl     String   @default("")
  modelName   String   @default("")
  encryptedKey String  // AES-256-GCM ciphertext
  maskedKey   String   @default("")
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// Customer-mode conversations
model CustomerConversation {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String   @default("Untitled Conversation")
  business    String   @default("")
  audience    String   @default("")
  tone        String   @default("friendly")
  language    String   @default("en")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    CustomerMessage[]
}

model CustomerMessage {
  id              String   @id @default(cuid())
  conversationId  String
  conversation    CustomerConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            String
  content         String   @default("")
  meta            String   @default("{}")
  tokens          Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([conversationId])
}

// === V2 models ===

// Team workspaces — multiple users sharing agents
model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String   @default("")
  // Owner is the user who created the team (always has admin role via TeamMember)
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  // Plan overrides per-team (optional)
  plan        String   @default("team")
  maxAgents   Int      @default(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     TeamMember[]
  agents      Agent[]
  auditLogs   AuditLog[]
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // owner | admin | editor | viewer
  role      String   @default("viewer")
  invitedAt DateTime @default(now())
  joinedAt  DateTime?
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // agent.create, agent.update, agent.delete, member.invite, member.remove, integration.connect, etc.
  resourceType String @default("")
  resourceId  String @default("")
  // IP + user agent for security audits
  ipAddress String   @default("")
  userAgent String   @default("")
  // Arbitrary metadata
  meta      String   @default("{}")
  createdAt DateTime @default(now())

  @@index([teamId, createdAt])
  @@index([userId, createdAt])
}

// Public API keys for programmatic access (REST API + JS SDK)
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Friendly label e.g. "Production server", "Zapier integration"
  label       String
  // The actual key — stored as `am_live_<random>`. Hashed (SHA-256) at rest for security.
  // We return the plaintext only ONCE on creation; subsequent reads compare hashes.
  hashedKey   String   @unique
  prefix      String   @default("") // first 8 chars for display: "am_live_abc..."
  // Scopes: comma-separated list — "agents:read", "agents:run", "agents:write", "templates:read"
  scopes      String   @default("agents:read,agents:run")
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// Scheduled agent runs — cron-based
model Schedule {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Cron expression e.g. "0 9 * * *" (daily 9am), "*/30 * * * *" (every 30 min)
  cron        String
  // Timezone for the cron — defaults to UTC
  timezone    String   @default("UTC")
  // Static input to feed the agent on each scheduled run
  input       String   @default("")
  // Enabled flag — pause without deleting
  enabled     Boolean  @default(true)
  // Last run info (for the UI)
  lastRunAt   DateTime?
  lastRunStatus String @default("") // success | error | ""
  nextRunAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([nextRunAt])
}

// Webhook triggers — external systems can fire an agent via unique URL
model WebhookTrigger {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  // Unique secret token in the URL: /api/triggers/webhook/<token>
  token       String   @unique
  // Optional: secret for HMAC signature verification
  secret      String   @default("")
  // Optional: filter — only fire if the payload matches this JMESPath expression
  filterExpr  String   @default("")
  // Map payload fields to agent input via template: "User said: {{payload.message.text}}"
  inputTemplate String @default("{{payload}}")
  enabled     Boolean  @default(true)
  lastTriggeredAt DateTime?
  triggerCount Int     @default(0)
  createdAt   DateTime @default(now())

  @@index([agentId])
}

// RAG: embedded documents for retrieval
model Document {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  title       String
  // Original content (truncated if huge)
  content     String   @default("")
  source      String   @default("") // URL or filename
  type        String   @default("text") // text | pdf | url | markdown
  // Chunked + embedded — array of {chunk, embedding} stored as JSON
  // Embedding is a 384-dim float array (Xenova all-MiniLM-L6-v2)
  chunks      String   @default("[]")
  chunkCount  Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([agentId])
}

// Human-in-the-loop approval — pauses a workflow at an "approval" node until
// the user approves or rejects (or it auto-expires after N hours).
model Approval {
  id          String   @id @default(cuid())
  agentId     String
  runId       String   @default("")
  nodeId      String
  // The input/output context that needs approval
  context     String   @default("")
  // pending | approved | rejected | expired
  status      String   @default("pending")
  // Who approved/rejected (user id)
  decidedById String?
  decidedAt   DateTime?
  // Optional comment from the approver
  comment     String   @default("")
  // Auto-expire after 7 days if no decision
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([agentId, status])
  @@index([runId])
}

// OAuth connectors — one-click connect to Google, GitHub, Slack, Notion, etc.
// Tokens are encrypted at rest with AES-256-GCM (src/lib/crypto.ts).
model OAuthToken {
  id          String   @id @default(cuid())
  userId      String
  // Provider key: "google" | "github" | "slack" | "notion" | "microsoft" | "discord" | "linear" | "asana"
  provider    String
  // Encrypted access token (AES-256-GCM)
  encryptedAccessToken String
  // Encrypted refresh token (if provider supports it)
  encryptedRefreshToken String @default("")
  // Token expiration (if known)
  expiresAt   DateTime?
  // Scopes granted by the user
  scopes      String   @default("")
  // Provider-specific user info (e.g. email, name, avatar)
  providerUserId   String @default("")
  providerEmail    String @default("")
  providerUserName String @default("")
  providerAvatar   String @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
}
