# ===========================================
# AGENTMARK Environment Variables
# ===========================================
# Copy this file to .env (for local dev) or set these in Vercel
# Project Settings → Environment Variables (for production).
#
# Lines marked [REQUIRED] must be set or the app won't work.
# Lines marked [OPTIONAL] enable specific features.
# ===========================================

# ---- DATABASE ----
# [REQUIRED] Vercel Postgres connection string.
# Create one at: https://vercel.com/dashboard/storage → Create Database → Postgres (Neon)
# Then click "Connect to Project" — Vercel auto-fills this env var.
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=

# ---- ENCRYPTION KEY ----
# [REQUIRED] 64-char hex string used to encrypt user API keys at rest.
# Generate one locally by running: openssl rand -hex 32
APP_ENCRYPTION_KEY=

# ---- FIREBASE (Google Login) ----
# [REQUIRED] From Firebase Console → Project Settings → General → Your apps → Web app
# https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=yourproject.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=yourproject
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=yourproject.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# ---- PAYSTACK (Billing — coming soon) ----
# [OPTIONAL] Leave empty to show "Coming Soon" in the Billing view.
# Get keys at: https://dashboard.paystack.co/#/settings/keys
PAYSTACK_SECRET_KEY=
PAYSTACK_PLAN_PRO=
PAYSTACK_PLAN_TEAM=

# ---- STRIPE CONNECT (Marketplace — let users sell templates) ----
# [OPTIONAL] Lets users connect their own Stripe account to sell paid templates.
# The platform takes 20% fee; the rest goes to the creator.
# Get keys at: https://dashboard.stripe.com → Connect → Settings
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=

# ---- SCHEDULER + EMAIL POLL SECURITY ----
# [OPTIONAL] Random strings to protect cron endpoints from being hit by anyone.
# Vercel Cron sends these in the Authorization header. Generate with: openssl rand -hex 16
SCHEDULER_API_KEY=
EMAIL_POLL_API_KEY=

# ---- AI MODELS (GLM-4.6) ----
# [OPTIONAL] Without these, the app falls back to free models.
# Set these to use GLM-4.6 or any OpenAI-compatible API.
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_API_KEY=

# ---- TWILIO (Voice + SMS agents) ----
# [OPTIONAL] Leave empty to disable voice/SMS features.
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- WHATSAPP (Meta Cloud API) ----
# [OPTIONAL] Leave empty to disable WhatsApp integration.
# https://developers.facebook.com/docs/whatsapp
WHATSAPP_VERIFY_TOKEN=

# ---- SLACK ----
# [OPTIONAL] Leave empty to disable Slack webhook signature verification.
SLACK_SIGNING_SECRET=

# ---- TELEGRAM ----
# [OPTIONAL] Not required — Telegram bot tokens are stored per-integration in the DB.
